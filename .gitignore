# Raw scan / intermediate pipeline files — never commit these
*.npy
*.nii
*.nii.gz
*.dcm
*.bak

# Python cache
__pycache__/
*.pyc
*.pyo

# Temp segmentation / output dirs
_seg/
_ts_out/
_breast_seg/

# Claude Code: ignore internal/local state, but TRACK the shared project config
# (skills, hooks, settings.json) so the whole team gets them.
.claude/*
!.claude/settings.json
!.claude/skills/
!.claude/hooks/
!.claude/commands/
.claude/settings.local.json

# Secrets / environment (never commit real keys)
# Match every .env variant (.env.production, .env.local, etc.) so a stray
# production secret file can't be committed; keep the public template.
.env*
!.env.example
.vercel

# Node
node_modules/

# Local minified build artifacts (Vercel produces these at deploy time; never commit them)
trainer.min.html
clerk-auth.min.js
trainer_test.html
