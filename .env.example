# Copy to .env.local for local dev, and set the same vars in the Vercel dashboard.
# NEVER commit real values — .env* is gitignored. Clerk Billing owns Stripe, so no Stripe keys here.

# --- Clerk (auth + billing) ---
CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# --- Cloudflare R2 (protected case-data storage) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=rtimagematch-data
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com

# --- Upstash Redis (rate limiting for /api/asset) ---
# OPTIONAL: if unset, /api/asset rate limiting is disabled (the paywall still works). Create a
# (free-tier) Upstash Redis DB and paste its REST URL + token; set the same in the Vercel dashboard.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
